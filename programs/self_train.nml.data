# NML Self-Training Test Data
# Learning: y = 2x + 1 on a single point (x=3, y=7)
# Architecture: 1→4→1 (4-neuron hidden layer)

# Initial weights (small random values)
@w1 shape=1,4 dtype=f64 data=0.5,-0.3,0.2,-0.1
@b1 shape=1,4 dtype=f64 data=0.1,0.1,0.1,0.1
@w2 shape=4,1 dtype=f64 data=0.4,-0.2,0.3,0.1
@b2 shape=1,1 dtype=f64 data=0.0

# Training point: x=3 → y=7
@test_input shape=1,1 data=3.0
@test_target shape=1,1 data=7.0
