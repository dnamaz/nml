; Denver forecast v2: avg temp + day_of_year, 14→32→7
LD    R1 @w1
LD    R2 @b1
LD    R3 @w2
LD    R4 @b2
LD    R0 @training_windows
LD    R9 @training_targets
TNET  #5000  #0.01  #0
ST    R8 @training_loss
LD    R0 @current_week
MMUL  R5 R0 R1
MADD  R5 R5 R2
RELU  R5 R5
MMUL  RA R5 R3
MADD  RA RA R4
ST    RA @forecast
HALT
