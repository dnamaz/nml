# Adaptive program test data
# Trains to learn y=2x+1, then predicts for x=3 (expected: 7)

# Initial weights (random)
@w1 shape=1,4 dtype=f64 data=0.5,-0.3,0.2,-0.1
@b1 shape=1,4 dtype=f64 data=0.1,0.1,0.1,0.1
@w2 shape=4,1 dtype=f64 data=0.4,-0.2,0.3,0.1
@b2 shape=1,1 dtype=f64 data=0.0

# Training data: x=3 → y=7
@training_input shape=1,1 data=3.0
@training_target shape=1,1 data=7.0

# Test input
@test_input shape=1,1 data=3.0
