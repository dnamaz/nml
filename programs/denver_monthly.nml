; Denver monthly average temperature predictor
; Input: month_fraction, sin(season), cos(season)
; Output: predicted monthly average temp
LD    R1 @w1
LD    R2 @b1
LD    R3 @w2
LD    R4 @b2
LD    R0 @training_months
LD    R9 @training_temps
TNET  #3000  #0.01  #0
ST    R8 @training_loss
LD    R0 @query_month
MMUL  R5 R0 R1
MADD  R5 R5 R2
RELU  R5 R5
MMUL  RA R5 R3
MADD  RA RA R4
ST    RA @prediction
HALT
