# Domain-specific data, models, and code (not part of NML core)
domain/

# Generated output (audit logs, provenance, build artifacts)
output/

# Compiled binaries (built from runtime/ via make)
/nml
/nmld
/nml-fast
/nml-metal
/nml-crypto

# Model weights (prevent accidental commits)
*.safetensors
*.bin
*.gguf

# Python
*.pyc
__pycache__/
*.egg-info/

# Node
node_modules/
bun.lock

# Cursor skill runner artifacts
terminal/hello.jsx

# OS
.DS_Store
Thumbs.db

# Logs
serve/logs/

# Cursor IDE (workspace state, skills, MCP config)
.cursor/

# Agent transcripts
agent-transcripts/

# External integration docs (drafts, not part of NML core)
docs/NanoLang_NML_Architecture.md
docs/NML_VibOS_Architecture.md
docs/NML_Multi_Agent_Implementation_Plan.md
plans/NanoLang_NML_Integration_Plan.md
plans/vibos-nml-collaboration-plan.md

# FastF1 session cache (auto-recreated by f1_pitstop_prep.py, ~50-100 MB per season)
f1_cache/

# Generated F1 program data (regenerated by prep scripts)
programs/f1_pitstop.nml.data
programs/f1_pitstop_norm.json
programs/f1_laptime.nml.data
programs/f1_laptime_norm.json

# Temp
/tmp/
plans/

# Test result artifacts (regenerated by test scripts)
tests/*.json
tests/retry_*.json
tests/compare_*.json
