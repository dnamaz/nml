; Opcode Coverage: Memory (5 opcodes)
; Tests: LD, ST, MOV, ALLC, LEAF

; LEAF — load immediate constant
LEAF  R0 #42.0
ST    R0 @leaf_result

; ALLC — allocate zero tensor
ALLC  R1 #[4]
ST    R1 @allc_result

; LD — load from memory
LD    R2 @test_data
ST    R2 @ld_result

; MOV — copy register
MOV   R3 R0
ST    R3 @mov_result

; ST — store (already used above, but explicit test)
LEAF  R4 #99.0
ST    R4 @st_result

HALT
